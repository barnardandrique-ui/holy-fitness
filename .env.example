# Copy this file to .env, fill in real values, and never commit .env itself.

# Your Anthropic API key. Get one at https://console.anthropic.com/
# This is only ever read server-side (in api/plan/generate.js) — it is never
# sent to the browser.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# A long, random, secret string used to sign login session cookies.
# Generate one with: openssl rand -base64 48
SESSION_SECRET=replace-this-with-a-long-random-string

# Not used yet — the app currently stores users in a local JSON file
# (see lib/db.js). Before hosting this for real users, swap lib/db.js to use
# a real database and set its connection string here.
# DATABASE_URL=
